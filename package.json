{
  "name": "intent-planner",
  "version": "0.25.0",
  "description": "AI コーディングエージェント (Claude Code / Codex / Gemini CLI) に実装を頼む前に「何を作りたいか・何を守りたいか」を一緒に整理し、実装中も意図をブレさせない軽量 Intent Planning workflow。詰めた意図を kiro / cc-sdd / OpenSpec の spec フローへ橋渡しし、新規プロダクト開発から大規模リファクタ・レガシー改修まで、npx 一発で skill + scaffold を配置。",
  "type": "module",
  "author": "Yoshishige Tsuji <tsuji@coccole.biz>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ijust/intent-planner.git"
  },
  "homepage": "https://github.com/ijust/intent-planner#readme",
  "bugs": {
    "url": "https://github.com/ijust/intent-planner/issues"
  },
  "bin": {
    "intent-planner": "bin/cli.mjs"
  },
  "files": [
    "templates",
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "build": "node scripts/build-dist.mjs",
    "prepublishOnly": "node scripts/publish-check.mjs"
  },
  "dependencies": {
    "handoff-bridge": "0.1.3",
    "term-drift": "0.3.3"
  },
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
